SERVER_PORT=8080

DB_URL=jdbc:mysql://localhost:3306/pkm_box_store?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=pkm_user
DB_PASSWORD=change-me

FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_BASELINE_VERSION=0

JPA_DDL_AUTO=validate
HIBERNATE_FORMAT_SQL=true
HIBERNATE_DEFAULT_BATCH_FETCH_SIZE=100

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
JWT_ACCESS_TOKEN_EXPIRATION_MS=3600000
JWT_REFRESH_TOKEN_EXPIRATION_MS=1209600000

CORS_ALLOWED_ORIGINS=http://localhost:3000

MAIL_MODE=LOG
MAIL_FROM=no-reply@pkm-box-store.local
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

EMAIL_VERIFICATION_CODE_TTL_SECONDS=300
EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=600
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_FAILED_ATTEMPTS=5
EMAIL_VERIFICATION_MAX_SENDS_PER_WINDOW=5
EMAIL_VERIFICATION_SEND_WINDOW_SECONDS=3600
EMAIL_VERIFICATION_CLEANUP_RETENTION_DAYS=7
EMAIL_VERIFICATION_CLEANUP_CRON=0 20 3 * * *

TOSS_PAYMENTS_SECRET_KEY=
TOSS_PAYMENTS_CLIENT_KEY=

AWS_S3_BUCKET=
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_SWAGGER_UI_ENABLED=true

LOGGING_LEVEL_HIBERNATE_SQL=debug
